# ============================================================
# TagSpec — Equipment Attribute Workspace — root environment
# Copy to .env for local development. NEVER commit the real .env.
# ============================================================

# ---- Application ----
APP_ENV=local
APP_NAME=TagSpec
LOG_LEVEL=INFO

# ---- Database (dedicated to THIS app; avoids the existing 5433 CMMS db) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5544
POSTGRES_DB=equipment_addl_info
POSTGRES_USER=eai_app
POSTGRES_PASSWORD=change_me_local_only

# Full SQLAlchemy/psycopg URL (built from the parts above by default).
# Override directly if you point at an external database.
DATABASE_URL=postgresql+psycopg://eai_app:change_me_local_only@localhost:5544/equipment_addl_info

# ---- Security / auth ----
# Generate a strong value in production: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-only-insecure-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# ---- CORS ----
CORS_ORIGINS=http://localhost:5173

# ---- Storage ----
STORAGE_DIR=./storage
UPLOAD_DIR=./storage/uploads
EXPORT_DIR=./storage/exports

# ---- Upload / import limits ----
MAX_UPLOAD_SIZE_MB=25
HEADER_SEARCH_ROWS=25

# ---- Tag claiming ----
CLAIM_EXPIRY_MINUTES=30
HEARTBEAT_INTERVAL_SECONDS=120
