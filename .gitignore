# ---- Secrets / environment ----
.env
.env.*
!.env.example
*.env
backend/.env
frontend/.env
frontend/.env.*
!frontend/.env.example

# ---- Company / uploaded / generated data (NEVER commit) ----
*.xlsx
*.xlsm
*.xls
storage/uploads/*
storage/exports/*
!storage/uploads/.gitkeep
!storage/exports/.gitkeep
local-data/*
!local-data/.gitkeep

# ---- Python / backend ----
backend/.venv/
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
.python-version

# ---- Node / frontend ----
node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
*.local

# ---- Runtime (local dev process logs + PIDs) ----
.runtime/
*.pid
*.tsbuildinfo

# ---- Editors / OS ----
.vscode/
.idea/
.DS_Store
*.swp
*.log
